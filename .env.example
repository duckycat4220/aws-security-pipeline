APP_NAME=AWS Security Intelligence Pipeline
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

SQS_QUEUE_NAME=security-events-queue
SQS_DLQ_NAME=security-events-dlq
SQS_MAX_RECEIVE_COUNT=3

CALLBACK_URL=https://webhook.site/replace-me
CALLBACK_TIMEOUT_SECONDS=10

# LLM: "mock" (rule-based, no cost) or "bedrock" (Claude via AWS Bedrock)
LLM_MODE=mock
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001
BEDROCK_REGION=us-east-1